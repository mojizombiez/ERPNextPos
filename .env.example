# FTP Deployment Credentials
FTP_HOST=your_ftp_host
FTP_USER=your_ftp_user
FTP_PASSWORD=your_ftp_password
FTP_DIR_WINDOWS=/erpnext/windows
FTP_DIR_LINUX=/erpnext/linux

# ERPNext API Credentials
ERP_API_URL=https://your-site.frappe.cloud
ERP_API_KEY=your_api_key
ERP_API_SECRET=your_api_secret

# Update Settings
UPDATE_URL=https://your-site.com/erpnext/windows/update.json
DOWNLOAD_BASE_URL_WINDOWS=https://your-site.com/erpnext/windows
DOWNLOAD_BASE_URL_LINUX=https://your-site.com/erpnext/linux
